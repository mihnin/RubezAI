{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubezh-ai/contracts/documents.schema.json",
  "title": "Контракт документов: /api/documents*",
  "description": "Эндпойнты загрузки/чтения документов. content в chunks — sanitized (raw только в MinIO). status='deleted' — soft-delete после hard-delete объекта в MinIO. План iteration-10.md.",
  "$defs": {
    "DocumentStatus": {
      "type": "string",
      "enum": ["pending", "processing", "done", "failed", "deleted"]
    },
    "DocumentPhase": {
      "type": ["string", "null"],
      "enum": ["parsing", "chunking", "sanitizing", "embedding", null]
    },
    "Document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "owner_id", "filename", "status",
        "processing_attempts", "created_at", "updated_at"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "owner_id": { "type": "string", "format": "uuid" },
        "filename": { "type": "string" },
        "content_type": { "type": ["string", "null"] },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "status": { "$ref": "#/$defs/DocumentStatus" },
        "phase": { "$ref": "#/$defs/DocumentPhase" },
        "error": { "type": ["string", "null"] },
        "processing_attempts": { "type": "integer", "minimum": 0 },
        "processing_started_at": { "type": ["string", "null"], "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "DocumentList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documents"],
      "properties": {
        "documents": {
          "type": "array",
          "items": { "$ref": "#/$defs/Document" }
        }
      }
    },
    "DocumentChunk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "document_id", "chunk_index", "content", "created_at"],
      "description": "content — обезличенный текст (план §Р4). Никогда не отдаётся raw содержимое документа.",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "document_id": { "type": "string", "format": "uuid" },
        "chunk_index": { "type": "integer", "minimum": 0 },
        "content": { "type": "string" },
        "token_count": { "type": ["integer", "null"], "minimum": 0 },
        "risk_level": {
          "type": ["string", "null"],
          "enum": ["low", "medium", "high", "critical", null]
        },
        "risk_score": {
          "type": ["number", "null"], "minimum": 0, "maximum": 1
        },
        "risk_classes": {
          "type": "array",
          "items": { "type": "string", "enum": ["pii", "secret", "commercial"] }
        },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "DocumentChunkList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id", "chunks"],
      "properties": {
        "document_id": { "type": "string", "format": "uuid" },
        "chunks": {
          "type": "array",
          "items": { "$ref": "#/$defs/DocumentChunk" }
        }
      }
    }
  }
}
