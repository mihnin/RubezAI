# Рубеж ИИ — пример переменных окружения.
# Скопируйте в .env и при необходимости измените значения.
# .env в .gitignore — НЕ коммитить. Значения ниже — для локальной разработки.

# --- PostgreSQL ---
POSTGRES_USER=rubezh
POSTGRES_PASSWORD=rubezh
POSTGRES_DB=rubezh
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- MinIO ---
MINIO_ROOT_USER=rubezh
MINIO_ROOT_PASSWORD=rubezh-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=rubezh-documents

# --- rubezh-api (Go) ---
API_PORT=8080
API_LOG_LEVEL=info

# Секрет подписи dev-токена аутентификации (MVP; заменяется на OIDC после MVP).
AUTH_DEV_TOKEN_SECRET=change_me_dev_only

# --- Шифрование mapping'ов псевдонимов (AES-GCM, 256-bit) ---
# Сгенерировать: openssl rand -base64 32
MAPPING_ENCRYPTION_KEY=

# --- Внутренние сервисы ---
SANITIZER_URL=http://rubezh-sanitizer:8001
WORKER_POLL_INTERVAL_SECONDS=5

# --- LLM-review санитайзера (фильтр 2/3, H.3) ---
# Локальная русскоязычная LLM как смысловой детектор (дополняет regex, НЕ
# принимает решений allow/deny; fail-open при недоступности). Все поля
# опциональны: пустой URL/MODEL → фильтр 2 выключен, работает только regex.
# Из контейнера локальная LM Studio доступна как host.docker.internal.
# Reasoning-моделям (DeepSeek-R1) нужен запас по таймауту (сек).
SANITIZER_LLM_URL=
SANITIZER_LLM_MODEL=
SANITIZER_LLM_KEY=
SANITIZER_LLM_TIMEOUT=5.0

# --- LLM ---
# mock — встроенный mock-провайдер; openai — OpenAI-совместимый endpoint (vLLM и т. п.)
LLM_DEFAULT_PROVIDER=mock

# --- Embedder (Итерация 11 §Р2) ---
# Векторизатор для RAG: ОБЯЗАН быть идентичным в rubezh-api (query-embed)
# и rubezh-worker (doc-embed), иначе cosine ranking бесполезен.
# Размерность фиксирована 1024 (схема embeddings.vector(1024)); провайдер
# с другим dim → fail-closed.
#
# EMBEDDER_KIND: "mock" (default, детерминированный SHA-256) | "openai_compatible"
# Из контейнера локальная LM Studio доступна как host.docker.internal:1234.
# Для real-семантики поднимите в LM Studio embedding-модель (bge-m3 / nomic-embed-text).
EMBEDDER_KIND=mock
# EMBEDDER_URL=http://host.docker.internal:1234
# EMBEDDER_MODEL=bge-m3
# EMBEDDER_API_KEY=
# EMBEDDER_TIMEOUT_SECONDS=30

# --- RAG в чате (Итерация 11 §Р4) ---
# Operator-level toggle: даже при rag.enabled=true в запросе RAG-конвейер
# не запускается, если RAG_ENABLED=false. Default — RAG включён.
# RAG_ENABLED=false

# --- OIDC-вход сотрудника (K.1) ---
# Пусто → выключен, остаётся dev-login (выбор роли). Заполнено → кнопка
# «Войти через корпоративную учётную запись» в Web + CLI loopback.
# Локальный тест с встроенным dex (docker compose --profile dev-idp up -d dex):
#   ДОБАВЬТЕ в hosts-файл ОС строку:  127.0.0.1   dex
#   (Windows: C:\Windows\System32\drivers\etc\hosts) — нужно браузеру.
# OIDC_ISSUER=http://dex:5556/dex
# OIDC_CLIENT_ID=rubezh
# OIDC_CLIENT_SECRET=rubezh-dev-client-secret
# OIDC_REDIRECT_URL=http://localhost:8080/api/auth/oidc/callback
# OIDC_FRONTEND_URL=http://localhost:5173
# OIDC_ROLE_CLAIM=groups
# OIDC_ROLE_MAP=rubezh-admins:admin,rubezh-ib:security_officer
# Прод: укажите issuer своего IdP (AD/ADFS/Keycloak/Avanpost/Google и т.п.).

# Ключ для OpenAI-совместимых провайдеров (vLLM, DeepSeek). Пусто — для mock.
# DEPRECATED (Итерация 9.5): per-provider api_key теперь хранится в БД
# зашифрованным (AES-256-GCM, AAD=name). Этот env используется только
# как fallback для провайдеров, созданных до Итерации 9.5 (без
# api_key_encrypted). Новые провайдеры: POST /api/models с api_key
# в теле + POST /api/models/:id/api-key для обновления.
LLM_API_KEY=

# --- SSH-CLI bridge для внешних LLM (Codex / Claude / Gemini / Grok CLI) ---
# Codex/Claude/Gemini/Grok CLI заранее залогинены серверной учёткой на
# удалённом Ubuntu-сервере. rubezh-api подключается по SSH (ed25519,
# StrictHostKeyChecking через known_hosts) и запускает /usr/local/bin/ai-bridge
# <provider> со stdin JSON. Никаких API-ключей провайдеров не нужно.
#
# Контракт stdin/stdout: deploy/ssh-bridge/README.md.
# Хост-пути приватного ключа и known_hosts задаются ТОЛЬКО локально (вне
# репозитория): см. RUBEZH_SSH_KEY_PATH ниже. В контейнере rubezh-api
# они монтируются read-only в /run/secrets/*.
#
# SSH_LLM_ENABLED=false (default) → провайдеры с adapter=ssh_cli не
# регистрируются даже после миграции 000017. Включается явно.
SSH_LLM_ENABLED=false
SSH_LLM_HOST=
SSH_LLM_PORT=22
SSH_LLM_USER=
SSH_LLM_REMOTE_COMMAND=/usr/local/bin/ai-bridge
SSH_LLM_TIMEOUT_SECONDS=180

# Внутри контейнера rubezh-api пути зафиксированы compose'ом; менять
# не нужно (присутствуют здесь только для документации).
# SSH_LLM_KEY_PATH=/run/secrets/rubezh_ai_ssh_key
# SSH_LLM_KNOWN_HOSTS_PATH=/run/secrets/known_hosts

# Хост-пути для docker compose (read-only mount → /run/secrets/*).
# ВНИМАНИЕ: эти файлы НЕ коммитить в репозиторий. На Windows используйте
# обычные пути вида C:/Users/<user>/.ssh/...; на Linux — /home/<user>/.ssh/...
# Если bridge отключён (SSH_LLM_ENABLED=false), можно оставить пустыми —
# compose смонтирует /dev/null как заглушку (но bridge всё равно не стартует).
# RUBEZH_SSH_KEY_PATH=C:/Users/Mih10/.ssh/rubezai_ruvds_aiagent_ed25519
# RUBEZH_SSH_KNOWN_HOSTS_PATH=C:/Users/Mih10/.ssh/known_hosts
