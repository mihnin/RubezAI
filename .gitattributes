# Нормализация переводов строк. Контейнеры собираются под Linux —
# Makefile, shell-скрипты и Dockerfile обязаны иметь LF.
* text=auto eol=lf

# Windows-скрипты — CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Бинарные форматы — не нормализовать.
*.png binary
*.jpg binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
